# Configuration npm pour CLICOM

# Installation en production uniquement (pas de devDependencies)
# Utilisé automatiquement par npm ci --omit=dev
production=false

# Cache npm pour accélérer les installations
cache=.npm-cache

# Logs moins verbeux
loglevel=warn

# Sauvegarde exacte des versions (pour reproductibilité)
save-exact=true

# Pas de télémétrie
audit=false
fund=false
