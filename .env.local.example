# ─────────────────────────────────────────────────────────────────────────────
# CLICOM — Variables d'environnement (côté SERVEUR)
# Copiez ce fichier en .env.local et remplissez les valeurs.
# ⚠️  Ne jamais préfixer avec NEXT_PUBLIC_ les clés secrètes ci-dessous.
#     NEXT_PUBLIC_ expose la variable au navigateur (bundle JS public).
# ─────────────────────────────────────────────────────────────────────────────

# ── Resend — Envoi d'emails transactionnels ──────────────────────────────────
# Créez un compte sur https://resend.com et générez une API key.
# ⚠️  Doit rester STRICTEMENT côté serveur — jamais de NEXT_PUBLIC_ ici.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse email de destination pour les messages du formulaire de contact.
CONTACT_EMAIL=hello@clicom.ch

# ── Cloudflare Turnstile — Protection anti-spam & anti-bot ──────────────────
# Créez un site sur https://dash.cloudflare.com → Turnstile
# Choisissez le widget type "Managed" (recommandé) ou "Invisible".
#
# La clé SECRÈTE reste côté serveur uniquement (validation API /api/contact).
# ⚠️  Jamais de NEXT_PUBLIC_ sur la clé secrète.
TURNSTILE_SECRET_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxxxxxxxx

# La clé PUBLIQUE (site key) doit être exposée au navigateur pour le widget.
# ✅  Celle-ci DOIT avoir le préfixe NEXT_PUBLIC_ pour être lisible côté client.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Base de données (optionnel selon votre setup) ────────────────────────────
# DATABASE_URL=file:./db/custom.db

# ── Clés de développement Cloudflare Turnstile ───────────────────────────────
# Pour tester en local SANS vrai compte Cloudflare, utilisez ces clés de test :
#   Site key (toujours OK) :  1x00000000000000000000AA
#   Secret key (toujours OK): 1x0000000000000000000000000000000AA
#   Site key (toujours KO) :  2x00000000000000000000AB
#   Secret key (toujours KO): 2x0000000000000000000000000000000AA
# En dev, si TURNSTILE_SECRET_KEY est vide, la vérification est ignorée (bypass).
